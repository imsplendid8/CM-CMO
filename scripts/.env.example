# scripts/.env  (이 파일을 .env 로 복사해 값 채우기 · .env 는 절대 커밋 금지)
#
# ── 네이버 검색광고 API ──
# 발급: https://searchad.naver.com  →  도구 > API 사용 관리
#   · 액세스라이선스        → NAVER_AD_API_KEY
#   · 비밀키               → NAVER_AD_SECRET
#   · CUSTOMER ID(숫자)     → NAVER_AD_CUSTOMER  (계정 정보/우상단에 표시)
NAVER_AD_API_KEY=
NAVER_AD_SECRET=
NAVER_AD_CUSTOMER=

# ── 구글 Ads API ──
# 인증은 google-ads.yaml 로 관리(레포 루트 또는 ~/). 아래는 참고용.
# GOOGLE_ADS_CONFIGURATION_FILE_PATH=./google-ads.yaml
